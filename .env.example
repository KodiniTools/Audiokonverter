# ============================================================
# SERVER (server.js) – Pflicht-Variablen für Production
# ============================================================

# Port des Express-Servers (default: 9000)
PORT=9000

# Verzeichnis für konvertierte Dateien (default: ./files)
# FILES_DIR=/var/data/audiokonverter/files

# Narakeet Text-to-Speech API Key (https://www.narakeet.com)
# Ohne diesen Key ist der /api/tts Endpoint deaktiviert.
NARAKEET_API_KEY=

# Admin-Passwort für den Musik-Player (Playlists verwalten)
# Ohne diesen Wert sind alle Admin-Endpoints deaktiviert.
# Starkes Passwort wählen (mind. 20 Zeichen, Sonderzeichen)
ADMIN_PASSWORD=

# ============================================================
# FRONTEND (Vite) – Build-Zeit-Variablen
# ============================================================

# Backend API URL
VITE_API_URL=http://localhost:3001

# App Configuration
VITE_APP_NAME=Audio Konverter
VITE_APP_VERSION=2.0.0

# Max File Size (in bytes)
VITE_MAX_FILE_SIZE=314572800

# Supported Formats
VITE_SUPPORTED_FORMATS=mp3,wav,flac,ogg,aac,m4a

# Default Settings
VITE_DEFAULT_FORMAT=mp3
VITE_DEFAULT_QUALITY=7
VITE_DEFAULT_LOCALE=de
