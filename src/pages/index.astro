    /* ---------------------------------------------------------------
       HELPERS
       --------------------------------------------------------------- */
    function getNestedValue(obj, keyPath) {
      return keyPath.split('.').reduce(function(o, k) {
        return o && o[k] !== undefined ? o[k] : null;
      }, obj);
    }

    function getLocale() {
      return localStorage.getItem('locale') || 'de';
    }

    /* ---------------------------------------------------------------
       APPLY PAGE TRANSLATIONS
       Called on init and on every locale-changed event.
       --------------------------------------------------------------- */
    function applyPageTranslations() {
      var locale = getLocale();
      var t = translations[locale] || translations.de;

      // Translate all [data-i18n] elements
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        var value = getNestedValue(t, key);
        if (value !== null) {
          el.textContent = value;
        }
      });

      // Update typing title immediately (no re-animation)
      var typingTextEl = document.getElementById('typing-text');
      var cursorEl = document.getElementById('typing-cursor');
      var titleEl = document.getElementById('typing-title');
      if (typingTextEl && titleEl) {
        var newTitle = getNestedValue(t, 'app.title') || 'Audio Konverter';
        if (typingTextEl.dataset.typingDone === 'true') {
          typingTextEl.textContent = newTitle;
        }
        titleEl.setAttribute('aria-label', newTitle);
        typingTextEl.dataset.targetText = newTitle;
      }
      if (cursorEl && typingTextEl && typingTextEl.dataset.typingDone === 'true') {
        cursorEl.classList.add('hidden');
      }

      // Update <html lang>
      document.documentElement.lang = locale;
    }

    /* ---------------------------------------------------------------
       TYPING ANIMATION (runs once on page load)
       --------------------------------------------------------------- */
    function startTypingAnimation() {
      var typingTextEl = document.getElementById('typing-text');
      var cursorEl = document.getElementById('typing-cursor');
      if (!typingTextEl) return;

      var locale = getLocale();
      var t = translations[locale] || translations.de;
      var fullText = getNestedValue(t, 'app.title') || 'Audio Konverter';
      typingTextEl.dataset.targetText = fullText;
      typingTextEl.textContent = '';
      typingTextEl.dataset.typingDone = 'false';

      var charIndex = 0;
      var speed = 80;

      function typeNext() {
        var target = typingTextEl.dataset.targetText || fullText;
        if (target !== fullText) {
          typingTextEl.textContent = target;
          typingTextEl.dataset.typingDone = 'true';
          if (cursorEl) cursorEl.classList.add('hidden');
          return;
        }
        if (charIndex < fullText.length) {
          typingTextEl.textContent = fullText.substring(0, charIndex + 1);
          charIndex++;
          setTimeout(typeNext, speed);
        } else {
          typingTextEl.dataset.typingDone = 'true';
          setTimeout(function() { if (cursorEl) cursorEl.classList.add('hidden'); }, 1500);
        }
      }

      setTimeout(typeNext, 400);
    }

    /* ---------------------------------------------------------------
       FAQ ACCORDION
       --------------------------------------------------------------- */
    function initFaqAccordion() {
      var grid = document.getElementById('faq-grid');
      if (!grid) return;

      grid.addEventListener('click', function(e) {
        var item = e.target.closest('.faq-item');
        if (!item) return;

        var wasActive = item.classList.contains('active');

        grid.querySelectorAll('.faq-item.active').forEach(function(el) {
          el.classList.remove('active');
          el.querySelector('.faq-toggle').textContent = '+';
        });

        if (!wasActive) {
          item.classList.add('active');
          item.querySelector('.faq-toggle').textContent = '\u2212';
        }
      });
    }

    /* ---------------------------------------------------------------
       SCROLL REVEAL (IntersectionObserver)
       --------------------------------------------------------------- */
    function initScrollReveal() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var delay = entry.target.getAttribute('data-reveal-delay');
            if (delay) {
              setTimeout(function() { entry.target.classList.add('revealed'); }, parseInt(delay, 10));
            } else {
              entry.target.classList.add('revealed');
            }
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-reveal]').forEach(function(el) {
        observer.observe(el);
      });
    }

    /* ---------------------------------------------------------------
       ANCHOR NAV — Active state follows scroll position
       --------------------------------------------------------------- */
    function initAnchorNav() {
      var nav = document.getElementById('anchor-nav');
      var links = document.querySelectorAll('.anchor-nav__link[data-anchor]');
      var sections = [];

      // Collect section elements
      links.forEach(function(link) {
        var id = link.getAttribute('data-anchor');
        var section = document.getElementById(id);
        if (section) sections.push({ id: id, el: section, link: link });
      });

      if (!sections.length) return;

      // Shadow on scroll
      var lastScroll = 0;
      function updateNav() {
        var scrollY = window.scrollY;

        // Add shadow when scrolled
        if (scrollY > 20) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }

        // Determine active section based on scroll position
        var activeId = sections[0].id; // default to first
        var offset = 140; // nav height + anchor nav + buffer

        for (var i = sections.length - 1; i >= 0; i--) {
          var rect = sections[i].el.getBoundingClientRect();
          if (rect.top <= offset) {
            activeId = sections[i].id;
            break;
          }
        }

        // Update active class
        links.forEach(function(link) {
          if (link.getAttribute('data-anchor') === activeId) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });

        lastScroll = scrollY;
      }

      // Throttle scroll handler
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            updateNav();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });

      // Initial state
      updateNav();
    }

    /* ---------------------------------------------------------------
       EVENT LISTENERS
       --------------------------------------------------------------- */

    // locale-changed from Nav (no page reload!)
    // Flow: Nav saves locale → translates itself → dispatches event
    // → Footer, Cookie-Banner, Page-Script receive & translate immediately
    window.addEventListener('locale-changed', function() {
      applyPageTranslations();
    });

    // Legacy event from NavControls.vue bridge
    window.addEventListener('language-changed', function(e) {
      if (e.detail && e.detail.lang) {
        localStorage.setItem('locale', e.detail.lang);
      }
      applyPageTranslations();
    });

    // Initialize on DOMContentLoaded
    document.addEventListener('DOMContentLoaded', function() {
      applyPageTranslations();
      startTypingAnimation();
      initFaqAccordion();
      initScrollReveal();
      initAnchorNav();
    });

  })();
  </script>

</body>
</html>
